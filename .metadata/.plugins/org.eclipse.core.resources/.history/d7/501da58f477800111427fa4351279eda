public class StringFunctions {

	public static void main(String[] args) {
		// TODO Auto-generated method stub
		String str = "Java Class";
		//Length
		System.out.println("1.Length: "+str.length());
		//charAt
		System.out.println("2.Character at Index (5): "+str.charAt(5));
		//substring
		System.out.println("3.Substring: "+str.substring(0));
		//toUppercase
		System.out.println("4.Uppercase: "+str.toUpperCase());
		//toLowercase
		System.out.println("5.Lowercase: "+str.toLowerCase());
		//concat
		System.out.println("6.contact: "+str.concat(" Language"));
		//equals
		String s1 = "Java";
		String s2 = "Java";
		System.out.println("7.Equals: "+s1.equals(s2));
		String s3 = "Java";
		String s4 = "Class";
		System.out.println("7.1 Equals: "+s3.equals(s4));
		//equalsIgnorecase
		System.out.println("8.EqualsIgnorecase: "+s1.equalsIgnoreCase(s3));
		System.out.println("8.1 EqualsIgnorecase: "+s2.equalsIgnoreCase(s4));
		//contains
		System.out.println("9.Contains: "+str.contains("Class"));
		//Replace
		System.out.println("10.Replace: "+str.replace("Class", "Programming"));
		//startsWith
		System.out.println("11.Starts With: "+str.startsWith("Java"));
	}

}
